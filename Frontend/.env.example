# Base URL of the backend API (host root or including /api — normalized either
# way). VITE_API_URL is preferred (set this on Vercel); VITE_API_BASE_URL is a
# legacy fallback. In a PRODUCTION build one of these MUST be set — the app will
# NOT fall back to a relative path / the current origin. In development, leave
# both empty to use the Vite dev proxy (/api -> VITE_API_PROXY_TARGET).
VITE_API_URL=https://nilecon-hr-backend.onrender.com
# VITE_API_BASE_URL=/api

# LINE LIFF app id (from the LINE Developers console). Required to run inside LINE.
VITE_LIFF_ID=

# DEV ONLY: bypass the LINE SDK and use this string as the employee's LINE id
# token. With the backend in mock mode the token becomes lineUserId "mock:<x>".
# The seeded employee is reachable with: emp-somchai
VITE_DEV_LINE_TOKEN=

# DEV ONLY: where `vite dev` proxies /api to.
VITE_API_PROXY_TARGET=http://localhost:4000
