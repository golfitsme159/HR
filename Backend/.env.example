# Server
NODE_ENV=development
PORT=4000

# MongoDB
MONGO_URI=mongodb://127.0.0.1:27017/nilecon_hr

# LINE Login / LIFF
# The Channel ID of your LINE Login channel (aud of the ID token).
LINE_CHANNEL_ID=2008604859

# LINE Messaging API channel access token (long-lived), used to PUSH approval /
# rejection Flex Messages to employees. Leave empty in dev/mock mode — pushes
# are then skipped gracefully instead of failing.
LINE_CHANNEL_ACCESS_TOKEN=ledLpQTW4bt76KxRir4wQC9brBycyRSp0gCCXBnn148xXERyLQzYg35crwyxTgEQlW3EITNCcY+DOF9jtkvX5xeHgI+M10rew1Iw+Rfw+i/3S7ldX2tkTYkR+OhFdbuNFca3T9RWbg1aWpI0j3Qk1AdB04t89/1O/w1cDnyilFU=

# When true (or when LINE_CHANNEL_ID is empty), the LINE ID token is NOT
# verified against LINE's servers. Instead the raw idToken is treated as the
# lineUserId (prefixed with "mock:"). Use ONLY for local development / testing.
LINE_MOCK_ENABLED=true

# JWT for HR/Admin web sessions
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=2h

# Password hashing cost
BCRYPT_SALT_ROUNDS=10

# Default HR/Admin account created by `npm run seed`
HR_DEFAULT_USERNAME=admin
HR_DEFAULT_PASSWORD=ChangeMe123!
